PORT=5000
NODE_ENV=development
JWT_SECRET=supersecretjwtkeychangeitinproduction
JWT_EXPIRES_IN=24h

# Database Configuration
# Default is sqlite. To use postgres or mysql, change DB_CLIENT to 'pg' or 'mysql2'
# and set the connection parameters.
DB_CLIENT=sqlite3
DB_CONNECTION=./groundwater.sqlite

# Optional Postgres/MySQL configuration:
# DB_CLIENT=pg
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=secret
# DB_DATABASE=groundwater

# Scheduled Job Configuration
# Set the cron pattern. Default '*/15 * * * *' is every 15 minutes.
# For quick demo purposes, you can use '* * * * *' (every minute) or run manually.
ANALYSIS_CRON_INTERVAL=* * * * *

# Notification SMTP Settings (Optional)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=groundwater-alerts@gov.env
