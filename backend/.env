PORT=5000
NODE_ENV=development
JWT_SECRET=supersecretjwtkeychangeitinproduction
JWT_EXPIRES_IN=24h

# MySQL connection — fill in your credentials
DATABASE_URL="mysql://root:@localhost:3306/groundwater_db"

# Run analysis cron job every minute for demonstration and testing purposes
ANALYSIS_CRON_INTERVAL=* * * * *

# Notification SMTP Settings (Mocked in service if empty)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=groundwater-alerts@gov.env
